# academy-1198 Railway environment

# Railway volume mount path.
# In Railway: Service -> Volumes -> Add Volume -> Mount Path = /data
RAILWAY_VOLUME_MOUNT_PATH=/data

# Public Railway domain. Without https:// is okay.
RAILWAY_PUBLIC_DOMAIN=academy-1198-production.up.railway.app

# Optional full public URL. If set, this has priority over RAILWAY_PUBLIC_DOMAIN.
# PUBLIC_BASE_URL=https://academy-1198-production.up.railway.app

# Default GPT Actions session.
DEFAULT_SESSION_ID=academy_1198_start

# Project label returned by API.
PROJECT_SLUG=academy-1198

# Max chars returned per repository file in /api/v1/turn/context.
MAX_FILE_CHARS=18000

# Local-only fallback. Do not set this on Railway unless you know why.
# DATA_DIR=./data
